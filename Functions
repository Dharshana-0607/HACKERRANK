#include <iostream>
#include <cstdio>
#include <algorithm> // For std::max
using namespace std;
int max_of_four(int a, int b, int c, int d) {
    int max1 = max(a, b);
    int max2 = max(c, d);
    return max(max1, max2);
}
int main() {
    int a, b, c, d;
    scanf("%d %d %d %d", &a, &b, &c, &d);
    int res = max_of_four(a, b, c, d);
    printf("%d", res); 
    return 0;
}
