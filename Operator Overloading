
class Matrix {
public:
    vector<vector<int>> a;
    Matrix operator+(const Matrix& other) {
        Matrix result;
        int rows = a.size();
        int cols = a[0].size();
        result.a.resize(rows, vector<int>(cols));
        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                // Add corresponding elements
                result.a[i][j] = this->a[i][j] + other.a[i][j];
            }
        }
        return result;
    }
};

